diff -urN gcc-13.1.0.orig/gcc/testsuite/gcc.target/sh/pr49263-5.c gcc-13.1.0/gcc/testsuite/gcc.target/sh/pr49263-5.c
--- gcc-13.1.0.orig/gcc/testsuite/gcc.target/sh/pr49263-5.c	1970-01-01 03:00:00.000000000 +0300
+++ gcc-13.1.0/gcc/testsuite/gcc.target/sh/pr49263-5.c	2023-07-14 10:42:43.241558284 +0300
@@ -0,0 +1,37 @@
+/* Check that 'tst #64,r0' generated.  */
+/* { dg-do compile }  */
+/* { dg-options "-O2" }  */
+
+/* { dg-final { scan-assembler-times "tst\t#64,r0" 5 { target { ! sh2a } } } }  */
+
+/* { dg-final { scan-assembler-times "bld" 4 { target { sh2a } } } }  */
+/* { dg-final { scan-assembler-times "tst\t#64,r0" 1 { target { sh2a } } } }  */
+
+#define ADDR 0xFFFF0000
+#define P ((unsigned char *)ADDR)
+#define FLAG 64
+
+unsigned char f_tst_signed_char_var_eq (char v)
+{
+  return (v & FLAG) == FLAG;
+}
+
+unsigned char f_tst_unsigned_char_var_eq (unsigned char v)
+{
+  return (v & FLAG) == FLAG;
+}
+
+unsigned char f_tst_unsigned_symbol_eq (void)
+{
+  return (*P & FLAG) == FLAG;
+}
+
+unsigned char f_tst_unsigned_symbol_eq_zero (void)
+{
+  return (*P & FLAG) == 0;
+}
+
+unsigned char f_tst_unsigned_symbol_neq_zero (void)
+{
+  return (*P & FLAG) != 0;
+}
diff -urN gcc-13.1.0.orig/gcc/testsuite/gcc.target/sh/pr54089-11.c gcc-13.1.0/gcc/testsuite/gcc.target/sh/pr54089-11.c
--- gcc-13.1.0.orig/gcc/testsuite/gcc.target/sh/pr54089-11.c	1970-01-01 03:00:00.000000000 +0300
+++ gcc-13.1.0/gcc/testsuite/gcc.target/sh/pr54089-11.c	2023-07-14 10:15:17.261719633 +0300
@@ -0,0 +1,48 @@
+/* Check hoisting.  */
+/* { dg-do compile }  */
+/* { dg-options "-O2" }  */
+
+/* { dg-final { check-function-bodies "**" "" "" } }  */
+
+/*
+**_f_loop1_rshift: { target { ! has_dyn_shift } }
+**	.*
+**	mov\.l	\.L\d+,(r\d+)
+**	.*
+**	sts\.l	pr,@-r15
+**	.*
+**	jsr	@\1
+**	.*
+**	dt	r\d+
+**	bf\.s.*
+*/
+
+/*
+**_f_loop2_rshift: { target { ! has_dyn_shift } }
+**	.*
+**	mov\.l	\.L\d+,(r\d+)
+**	.*
+**	sts\.l	pr,@-r15
+**	.*
+**	jsr	@\1
+**	.*
+**	jsr	@\1
+**	.*
+**	dt	r\d+
+**	bf\.s.*
+*/
+
+void f_loop1_rshift (int* a, unsigned int count)
+{
+  for (int i=0; i<count; i++)
+    a[i] >>= 6;
+}
+
+void f_loop2_rshift (int* a, int* b, unsigned int count)
+{
+  for (int i=0; i<count; i++)
+  {
+    a[i] >>= 6;
+    b[i] >>= 6;
+  }
+}

diff -urN gcc-13.1.0.orig/gcc/config/sh/sh_loop.cc gcc-13.1.0/gcc/config/sh/sh_loop.cc
--- gcc-13.1.0.orig/gcc/config/sh/sh_loop.cc	1970-01-01 03:00:00.000000000 +0300
+++ gcc-13.1.0/gcc/config/sh/sh_loop.cc	2023-07-14 10:20:43.031688175 +0300
@@ -0,0 +1,260 @@
+/* SH specific loop move invariants only optimization.
+   Copyright (C) 2023 Free Software Foundation, Inc.
+
+This file is part of GCC.
+
+GCC is free software; you can redistribute it and/or modify it under
+the terms of the GNU General Public License as published by the Free
+Software Foundation; either version 3, or (at your option) any later
+version.
+
+GCC is distributed in the hope that it will be useful, but WITHOUT ANY
+WARRANTY; without even the implied warranty of MERCHANTABILITY or
+FITNESS FOR A PARTICULAR PURPOSE.  See the GNU General Public License
+for more details.
+
+You should have received a copy of the GNU General Public License
+along with GCC; see the file COPYING3.  If not see
+<http://www.gnu.org/licenses/>.  */
+
+#include "config.h"
+#include "system.h"
+#include "coretypes.h"
+#include "backend.h"
+#include "target.h"
+#include "rtl.h"
+#include "tree.h"
+#include "cfghooks.h"
+#include "df.h"
+#include "regs.h"
+#include "cfgcleanup.h"
+#include "cfgloop.h"
+#include "tree-pass.h"
+
+/*
+These set of loop optimization passes are essentially copies of the
+generic RTL passes that are ran before the instruction combine pass
+by default.
+
+On SH instruction combination and splitting might produce constant loads
+or function address loads (for libcalls).  These passes are used to hoist
+those late emitted constant loads out of loops.
+*/
+
+namespace
+{
+
+static bool
+optimize_loop (function *fun)
+{
+  return (fun->machine->ashrsi3_libcall_expanded_late > 0
+	  || fun->machine->shad_expanded_late > 0)
+	 && (optimize > 1)
+	 && flag_move_loop_invariants;
+}
+
+// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
+
+const pass_data pass_data_sh_loop2 =
+{
+  RTL_PASS, // type
+  "", // name
+  OPTGROUP_LOOP, // optinfo_flags
+  TV_LOOP, // tv_id
+  0, // properties_required
+  0, // properties_provided
+  0, // properties_destroyed
+  0, // todo_flags_start
+  0, // todo_flags_finish
+};
+
+class sh_pass_loop2 : public rtl_opt_pass
+{
+public:
+  sh_pass_loop2 (gcc::context *ctxt, const char *name)
+    : rtl_opt_pass (pass_data_sh_loop2, ctxt)
+  {
+    this->name = name;
+  }
+
+  bool gate (function *) final override;
+};
+
+bool
+sh_pass_loop2::gate (function *fun)
+{
+  if (optimize_loop (fun))
+    return true;
+  else
+  {
+    /* No longer preserve loops, remove them now.  */
+    fun->curr_properties &= ~PROP_loops;
+    if (current_loops)
+      loop_optimizer_finalize ();
+    return false;
+  }
+}
+
+// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
+// Initialization of the RTL loop passes.
+
+static unsigned int
+rtl_loop_init (void)
+{
+  if (dump_file)
+  {
+    dump_reg_info (dump_file);
+    dump_flow_info (dump_file, dump_flags);
+  }
+  loop_optimizer_init (LOOPS_NORMAL | LOOPS_HAVE_RECORDED_EXITS);
+  return 0;
+}
+
+const pass_data pass_data_rtl_sh_loop_init =
+{
+  RTL_PASS, // type
+  "", // name
+  OPTGROUP_LOOP, // optinfo_flags
+  TV_LOOP, // tv_id
+  0, // properties_required
+  0, // properties_provided
+  0, // properties_destroyed
+  0, // todo_flags_start
+  0, // todo_flags_finish
+};
+
+class pass_rtl_sh_loop_init : public rtl_opt_pass
+{
+public:
+  pass_rtl_sh_loop_init (gcc::context *ctxt, const char* name)
+    : rtl_opt_pass (pass_data_rtl_sh_loop_init, ctxt)
+  {
+    this->name = name;
+  }
+
+  bool gate (function *fun) final override
+  {
+    return optimize_loop (fun);
+  }
+
+  unsigned int execute (function *) final override
+  {
+    return rtl_loop_init ();
+  }
+};
+
+// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
+// Finalization of the RTL loop passes.
+
+const pass_data pass_data_rtl_sh_loop_done =
+{
+  RTL_PASS, // type
+  "", // name
+  OPTGROUP_LOOP, // optinfo_flags
+  TV_LOOP, // tv_id
+  0, // properties_required
+  0, // properties_provided
+  PROP_loops, // properties_destroyed
+  0, // todo_flags_start
+  0, // todo_flags_finish
+};
+
+class pass_rtl_sh_loop_done : public rtl_opt_pass
+{
+public:
+  pass_rtl_sh_loop_done (gcc::context *ctxt, const char* name)
+    : rtl_opt_pass (pass_data_rtl_sh_loop_done, ctxt)
+  {
+    this->name = name;
+  }
+
+  bool gate (function *fun) final override
+  {
+    return optimize_loop (fun);
+  }
+
+  unsigned int execute (function *) final override;
+};
+
+unsigned int
+pass_rtl_sh_loop_done::execute (function *fun)
+{
+  /* No longer preserve loops, remove them now.  */
+  fun->curr_properties &= ~PROP_loops;
+  loop_optimizer_finalize ();
+  free_dominance_info (CDI_DOMINATORS);
+  cleanup_cfg (0);
+  if (dump_file)
+  {
+    dump_reg_info (dump_file);
+    dump_flow_info (dump_file, dump_flags);
+  }
+  return 0;
+}
+
+// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
+// Loop sh_invariant code motion.
+
+const pass_data pass_data_rtl_sh_move_loop_invariants =
+{
+  RTL_PASS, // type
+  "", // name
+  OPTGROUP_LOOP, // optinfo_flags
+  TV_LOOP_MOVE_INVARIANTS, // tv_id
+  0, // properties_required
+  0, // properties_provided
+  0, // properties_destroyed
+  0, // todo_flags_start
+  (TODO_df_verify | TODO_df_finish), // todo_flags_finish
+};
+
+class pass_rtl_sh_move_loop_invariants : public rtl_opt_pass
+{
+public:
+  pass_rtl_sh_move_loop_invariants (gcc::context *ctxt, const char* name)
+    : rtl_opt_pass (pass_data_rtl_sh_move_loop_invariants, ctxt)
+  {
+    this->name = name;
+  }
+  /* opt_pass methods:  */
+  bool gate (function *fun) final override
+  {
+    return optimize_loop (fun);
+  }
+  unsigned int execute (function *fun) final override
+  {
+    if (number_of_loops (fun) > 1)
+      move_loop_invariants ();
+    return 0;
+  }
+};
+
+} // anon namespace
+
+// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
+// This allows instantiating the passes somewhere else without having to pull
+// in a header file.
+
+rtl_opt_pass *
+make_pass_sh_loop2 (gcc::context *ctxt, const char *name)
+{
+  return new sh_pass_loop2 (ctxt, name);
+}
+
+rtl_opt_pass *
+make_pass_rtl_sh_loop_init (gcc::context *ctxt, const char* name)
+{
+  return new pass_rtl_sh_loop_init (ctxt, name);
+}
+
+rtl_opt_pass *
+make_pass_rtl_sh_loop_done (gcc::context *ctxt, const char* name)
+{
+  return new pass_rtl_sh_loop_done (ctxt, name);
+}
+
+rtl_opt_pass *
+make_pass_rtl_sh_move_loop_invar (gcc::context *ctxt, const char* name)
+{
+  return new pass_rtl_sh_move_loop_invariants (ctxt, name);
+}
